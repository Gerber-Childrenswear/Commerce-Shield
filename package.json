{
  "name": "commerce-shield",
  "version": "1.0.0",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "npm --prefix web install && npm --prefix web run build",
    "dev": "LOG_LEVEL=debug node server.js",
    "worker:install": "npm --prefix worker install",
    "worker:dev": "npm --prefix worker run dev",
    "worker:deploy": "npm --prefix worker run deploy",
    "worker:db:init": "npm --prefix worker run db:init"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
